# Frontend env (Vercel project). Copy to .env.local for local builds, or
# set in Vercel Project Settings -> Environment Variables.

# Base URL for the FastAPI backend hosted on Railway. Leave blank in dev
# (Vite proxies /api -> http://localhost:8000 via vite.config.js).
VITE_API_BASE_URL=https://your-service.up.railway.app
