# Two Microsoft Fabric warehouses are wired in. Both share the same
# Service Principal credentials but live in different workspaces, so
# each gets its own SQL endpoint + database name.

# ----------------------------------------------------------------------------
# Project 1 — Investment Portfolio warehouse
# ----------------------------------------------------------------------------
# Used by the pyodbc-token primary backend (TDS over port 1433).
FABRIC_SQL_ENDPOINT_P1=p1-workspace.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE_P1=portfolio_warehouse
# Used by the Fabric REST API fallback. Both must be GUIDs (not names).
# Find them in the Fabric portal URL: .../groups/{WORKSPACE_ID}/warehouses/{WAREHOUSE_ID}
FABRIC_WORKSPACE_ID_P1=00000000-0000-0000-0000-000000000000
FABRIC_WAREHOUSE_ID_P1=00000000-0000-0000-0000-000000000000

# ----------------------------------------------------------------------------
# Project 3 — Energy Security warehouse
# ----------------------------------------------------------------------------
FABRIC_SQL_ENDPOINT_P3=p3-workspace.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE_P3=energy_warehouse
FABRIC_WORKSPACE_ID_P3=00000000-0000-0000-0000-000000000000
FABRIC_WAREHOUSE_ID_P3=00000000-0000-0000-0000-000000000000

# Shared Service Principal (Microsoft Entra ID)
FABRIC_CLIENT_ID=00000000-0000-0000-0000-000000000000
FABRIC_CLIENT_SECRET=your-service-principal-secret
FABRIC_TENANT_ID=00000000-0000-0000-0000-000000000000

# Comma-separated list of allowed origins for CORS.
# Include the Vite dev server and your production frontend domain.
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# Optional. Force a specific connection method for debugging.
# Values: auto (default), pyodbc, rest
FABRIC_CONNECTION_MODE=auto

# Optional. Cache lifetime in seconds. Defaults to 3600 (1 hour).
CACHE_TTL_SECONDS=3600
